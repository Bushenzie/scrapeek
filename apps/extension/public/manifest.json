{
    "$schema": "https://json.schemastore.org/chrome-manifest",
    "manifest_version": 3,
    "name": "Scrapeek picker",
    "description": "Scrapeek elements picker",
    "version": "0.0.1",
    "action": {
        "default_popup": "index.html"
    },
    "content_scripts": [
        {
            "js": [
                "content.js"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "commands": {
        "pick": {
            "suggested_key": {
                "default": "Ctrl+Shift+L",
                "mac": "Command+Shift+L"
            },
            "description": "Shortcut to pick elements"
        }
    },
    "background": {
        "type": "module",
        "service_worker": "background.js"
    },
    "permissions": [
        "activeTab",
        "scripting",
        "commands"
    ],
    "host_permissions": [
        "http://*/*",
        "https://*/*"
    ]
}