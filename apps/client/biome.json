{
  "$schema": "https://biomejs.dev/schemas/2.2.2/schema.json",
  "root": false,
  "extends": "//",
  "files": {
    "includes": ["**", "!**/routeTree.gen.ts", "!**/.*/**"]
  },
  "linter": {
    "rules": {
      "correctness": {
        "useUniqueElementIds": "off",
        "noChildrenProp": "off"
      },
      "a11y": {
        "useKeyWithClickEvents": "off"
      },
      "suspicious": {
        "noArrayIndexKey": "off"
      }
    },
    "includes": ["**/*.ts", "**/*.tsx"]
  }
}
