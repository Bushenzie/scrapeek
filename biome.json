{
    "vcs": {
        "enabled": false,
        "clientKind": "git",
        "useIgnoreFile": false
    },
    "files": {
        "ignoreUnknown": false
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "tab",
        "indentWidth": 1,
        "includes": [
            "**/*.ts"
        ]
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true
        },
        "includes": [
            "**/*.ts"
        ]
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "double"
        }
    },
    "assist": {
        "enabled": true,
        "actions": {
            "source": {
                "organizeImports": "on"
            }
        }
    }
}